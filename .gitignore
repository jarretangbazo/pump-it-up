# =============================================================================
# Flu Shot Learning — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Data — never commit raw or processed data files
# -----------------------------------------------------------------------------
data/raw/
data/processed/
*.csv
*.parquet
*.feather
*.json
*.xlsx
.DS_Store

# Keep the folder structure but not the files
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep

# -----------------------------------------------------------------------------
# Models — .pkl files can be large and are reproducible from training scripts
# -----------------------------------------------------------------------------
models/
*.pkl
*.pickle
*.joblib
*.pt
*.pth

!models/.gitkeep

# -----------------------------------------------------------------------------
# Submissions
# -----------------------------------------------------------------------------
submissions/
!submissions/.gitkeep

# -----------------------------------------------------------------------------
# MLflow — experiment tracking data grows large quickly
# -----------------------------------------------------------------------------
mlruns/
mlartifacts/
.mlflow/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
!logs/.gitkeep

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
flu_env/
venv/
env/
.env/
.venv/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Notebook outputs (optional — remove these lines if you want outputs committed)
# *.ipynb

# -----------------------------------------------------------------------------
# Environment variables — may contain API keys or credentials
# -----------------------------------------------------------------------------
.env
.env.local
.env.production
*.env

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# -----------------------------------------------------------------------------
# IDEs and editors
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml

# Jupyter
.jupyter/

# Spyder
.spyderproject.cfg
.spyproject/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# Testing and coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# -----------------------------------------------------------------------------
# Streamlit
# -----------------------------------------------------------------------------
.streamlit/secrets.toml